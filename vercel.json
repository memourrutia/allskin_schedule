{
  "buildCommand":    "npm run build",
  "outputDirectory": "dist",
  "installCommand":  "npm install",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/:path*",     "destination": "/index.html" }
  ]
}
