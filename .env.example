# ─────────────────────────────────────────────────────────────────────────────
# VARIABLES DE ENTORNO — Agenda_Allskin / Dentalink Integration
# ─────────────────────────────────────────────────────────────────────────────
#
# INSTRUCCIONES:
#   1. Copia este archivo a .env (no lo subas a Git — ya está en .gitignore)
#   2. Completa los valores con los datos reales de Dentalink
#   3. En Vercel: Dashboard → Settings → Environment Variables → agregar cada una
#
# REGLAS DE SEGURIDAD:
#   ✗ Nunca hardcodees estos valores en el código fuente
#   ✗ Nunca uses el prefijo VITE_ para secretos (quedan expuestos en el bundle)
#   ✗ Nunca subas este archivo .env a Git con valores reales
#   ✓ Configura siempre desde Vercel Dashboard para producción
#
# ─────────────────────────────────────────────────────────────────────────────

# Token de autenticación de la API de Dentalink
# Obtener en: Dentalink → Configuración → API → Generar token
DENTALINK_API_TOKEN=

# ID de cliente de la cuenta Dentalink
# Obtener en: Dentalink → Configuración → API → id cliente
DENTALINK_CLIENT_ID=

# URL base de la API de Dentalink (confirmar con soporte si cambia)
DENTALINK_BASE_URL=https://api.dentalink.healthatom.com/api/v1

# ID numérico de la sucursal Allskin-Alpes en Dentalink
# Obtener ejecutando: GET /sucursales
DENTALINK_BRANCH_ID_ALLSKIN_ALPES=

# ID numérico del profesional por defecto para el agendamiento online
# Obtener ejecutando: GET /dentistas?id_sucursal={branch_id}
DENTALINK_DEFAULT_DENTIST_ID=

# ID numérico del sillón/recurso de la sucursal
# Obtener ejecutando: GET /sillones (o /recursos)
DENTALINK_DEFAULT_CHAIR_ID=

# ID del estado inicial de una cita nueva en Dentalink
# Obtener ejecutando: GET /citas/estados
# Probable valor: 1 (pendiente) o el que indique Dentalink
DENTALINK_DEFAULT_APPOINTMENT_STATUS_ID=

# Duración por defecto de una cita en minutos
# Se usa cuando no se especifica en el request
DENTALINK_DEFAULT_DURATION_MINUTES=30
