{
  "compilerOptions": {
    "target":           "es2022",
    "module":           "commonjs",
    "lib":              ["es2022"],
    "moduleResolution": "node",
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "strict":           true,
    "noUnusedLocals":   true,
    "noUnusedParameters": true,
    "outDir":           ".vercel/output/functions",
    "types":            ["node"]
  },
  "include": ["api/**/*.ts"]
}
